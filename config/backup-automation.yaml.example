# OpenStack Backup Automation Configuration Example
# This file demonstrates environment variable substitution

openstack:
  # Authentication method: "application_credential" or "password"
  auth_method: "${OPENSTACK_AUTH_METHOD:application_credential}"
  
  # OpenStack authentication URL
  auth_url: "${OPENSTACK_AUTH_URL}"
  
  # Project name
  project_name: "${OPENSTACK_PROJECT_NAME}"
  
  # Application Credential authentication (recommended)
  application_credential_id: "${OPENSTACK_APP_CRED_ID}"
  application_credential_secret: "${OPENSTACK_APP_CRED_SECRET}"
  
  # Username/Password authentication (alternative)
  # username: "${OPENSTACK_USERNAME}"
  # password: "${OPENSTACK_PASSWORD}"
  # user_domain_name: "${OPENSTACK_USER_DOMAIN:Default}"
  # project_domain_name: "${OPENSTACK_PROJECT_DOMAIN:Default}"

backup:
  # Full backup interval in days
  full_backup_interval_days: ${BACKUP_FULL_INTERVAL:7}
  
  # Maximum number of concurrent backup/snapshot operations
  max_concurrent_operations: ${BACKUP_MAX_CONCURRENT:5}
  
  # Timeout for individual operations in minutes
  operation_timeout_minutes: ${BACKUP_TIMEOUT:60}
  
  # Default retention period in days
  retention_days: ${BACKUP_RETENTION_DAYS:30}

notifications:
  # Email recipient for notifications
  email_recipient: "${NOTIFICATION_EMAIL_RECIPIENT}"
  
  # Email sender address
  email_sender: "${NOTIFICATION_EMAIL_SENDER:backup-system@example.com}"
  
  # SMTP server configuration
  smtp_server: "${SMTP_SERVER:localhost}"
  smtp_port: ${SMTP_PORT:25}
  use_tls: ${SMTP_USE_TLS:false}
  
  # SMTP authentication (optional)
  # smtp_username: "${SMTP_USERNAME}"
  # smtp_password: "${SMTP_PASSWORD}"

scheduling:
  # Scheduling mode: "cron" or "daemon"
  mode: "${SCHEDULING_MODE:cron}"
  
  # Check interval in minutes (for cron mode)
  check_interval_minutes: ${SCHEDULING_CHECK_INTERVAL:15}
  
  # Sleep interval in seconds (for daemon mode)
  daemon_sleep_seconds: ${SCHEDULING_DAEMON_SLEEP:60}

# Optional retention policies for specific resource types or tags
retention_policies:
  # Example: Different retention for critical systems
  critical:
    retention_days: ${RETENTION_CRITICAL_DAYS:90}
    min_backups_to_keep: ${RETENTION_CRITICAL_MIN:3}
    keep_last_full_backup: true
  
  # Example: Shorter retention for development systems
  development:
    retention_days: ${RETENTION_DEV_DAYS:14}
    min_backups_to_keep: ${RETENTION_DEV_MIN:1}
    keep_last_full_backup: true

# Database configuration
database_path: "${DATABASE_PATH:./backup.db}"

# Logging configuration
log_level: "${LOG_LEVEL:INFO}"
log_file: "${LOG_FILE}"