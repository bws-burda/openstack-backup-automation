#!/usr/bin/env python3
"""OpenStack Backup Automation - Wrapper script for development and testing."""

import os
import sys
import subprocess

# Get the directory where this script is located
script_dir = os.path.dirname(os.path.abspath(__file__))

def main():
    """Main entry point for the wrapper script."""
    
    # Add src directory to Python path for development
    src_path = os.path.join(script_dir, 'src')
    if os.path.exists(src_path):
        sys.path.insert(0, src_path)
    
    try:
        # Try to import and run the CLI directly (for development)
        from cli.main import main as cli_main
        cli_main()
    except ImportError:
        # Fall back to subprocess call (for installed package)
        try:
            cmd = [sys.executable, "-m", "src.cli.main"] + sys.argv[1:]
            os.chdir(script_dir)
            result = subprocess.run(cmd, cwd=script_dir)
            sys.exit(result.returncode)
        except Exception as e:
            print(f"Error running backup automation: {e}")
            print("Make sure the package is installed or run from the source directory.")
            sys.exit(1)

if __name__ == "__main__":
    try:
        main()
    except KeyboardInterrupt:
        print("\nOperation cancelled by user.")
        sys.exit(0)
    except Exception as e:
        print(f"Unexpected error: {e}")
        sys.exit(1)